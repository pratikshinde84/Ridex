<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Header -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/background"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@android:drawable/ic_menu_revert">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/profile"
            android:textColor="@color/black"
            android:textSize="20sp"
            android:textStyle="bold" />

    </androidx.appcompat.widget.Toolbar>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Profile Image Section -->
            <FrameLayout
                android:layout_width="120dp"
                android:layout_height="120dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ivProfileLarge"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="2dp"
                    android:src="@drawable/ic_launcher_foreground"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.RideX.Circle"
                    app:strokeColor="@color/divider_color"
                    app:strokeWidth="1dp"
                    android:background="#EFEFEF" />

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|end"
                    app:fabCustomSize="32dp"
                    app:maxImageSize="16dp"
                    android:src="@android:drawable/ic_menu_edit"
                    app:backgroundTint="@color/black"
                    app:tint="@color/white" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvProfileName"
                style="@style/TextAppearance.RideX.HeadlineLarge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Alex Johnson"
                android:textColor="@color/black" />

            <TextView
                android:id="@+id/tvProfilePhone"
                style="@style/TextAppearance.RideX.BodyMedium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="+1 (555) 000-1234"
                android:textColor="@color/on_surface_variant" />

            <TextView
                android:id="@+id/tvProfileEmail"
                style="@style/TextAppearance.RideX.BodyMedium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="alex.johnson@email.com"
                android:textColor="@color/on_surface_variant" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="#F3F1F9"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@android:drawable/checkbox_on_background"
                        app:tint="@color/black" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/verified_account"
                        android:textColor="@color/black"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Menu Card -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.RideX.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Edit Profile -->
                    <include
                        android:id="@+id/menuEditProfile"
                        layout="@layout/item_profile_menu"
                        app:icon="@android:drawable/ic_menu_myplaces"
                        app:title="@string/edit_profile" />

                    <View style="@style/Divider" />

                    <!-- Saved Places -->
                    <include
                        android:id="@+id/menuSavedPlaces"
                        layout="@layout/item_profile_menu"
                        app:icon="@android:drawable/ic_menu_save"
                        app:title="@string/saved_places" />

                    <View style="@style/Divider" />

                    <!-- Payment Methods -->
                    <include
                        android:id="@+id/menuPaymentMethods"
                        layout="@layout/item_profile_menu"
                        app:icon="@android:drawable/ic_menu_agenda"
                        app:title="@string/payment_methods" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:background="@color/input_bg" />

                    <!-- Ride History -->
                    <include
                        android:id="@+id/menuRideHistory"
                        layout="@layout/item_profile_menu"
                        app:icon="@android:drawable/ic_menu_recent_history"
                        app:title="@string/ride_history" />

                    <View style="@style/Divider" />

                    <!-- Refer & Earn -->
                    <include
                        android:id="@+id/menuRefer"
                        layout="@layout/item_profile_menu"
                        app:icon="@android:drawable/ic_menu_send"
                        app:title="@string/refer_earn" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:background="@color/input_bg" />

                    <!-- Help & Support -->
                    <include
                        android:id="@+id/menuHelp"
                        layout="@layout/item_profile_menu"
                        app:icon="@android:drawable/ic_menu_help"
                        app:title="@string/help_support" />

                    <View style="@style/Divider" />

                    <!-- Settings -->
                    <include
                        android:id="@+id/menuSettings"
                        layout="@layout/item_profile_menu"
                        app:icon="@android:drawable/ic_menu_preferences"
                        app:title="@string/settings" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Logout Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="24dp"
                android:backgroundTint="#FFF5F5"
                android:text="@string/logout"
                android:textAllCaps="false"
                android:textColor="#D32F2F"
                android:textStyle="bold"
                app:cornerRadius="16dp"
                app:icon="@android:drawable/ic_lock_power_off"
                app:iconGravity="textStart"
                app:iconTint="#D32F2F" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/app_version"
                android:textColor="@color/on_surface_variant"
                android:textSize="12sp" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="80dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>